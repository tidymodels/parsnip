ord_cars$cyl <- as.ordered(ord_cars$cyl)

car_fit <- 
  gen_additive_mod() |> 
  set_engine("vgam") |> 
  set_mode("classification") |> 
  fit(cyl ~ disp + s(wt) + am, data = ord_cars)
}\if{html}{\out{</div>}}

